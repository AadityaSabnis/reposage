# ─────────────────────────────────────────────────────────────────
# RepoSage configuration. Copy to `.env` and edit.
# ─────────────────────────────────────────────────────────────────

# Which repository RepoSage indexes and answers questions about.
# Absolute path on the host (or container) filesystem.
REPO_PATH=./

# Where the FAISS index + SQLite metadata DB are persisted.
DATA_DIR=./data

# ── Embeddings ───────────────────────────────────────────────────
# Local sentence-transformers model. Either a model name (downloaded
# from HuggingFace on first run) or an absolute path to a local copy.
# 384-dim retrieval-optimized model, ~33MB, free, no API key.
EMBEDDING_MODEL_PATH=BAAI/bge-small-en-v1.5

# ── LLM provider ─────────────────────────────────────────────────
# "ollama"  -> Try local Ollama first; if unavailable, fall back to Groq/OpenAI
# "hosted"  -> Skip Ollama, use Groq/OpenAI directly
LLM_PROVIDER=ollama

# -- ollama (automatic if running locally) --
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=phi3:mini
OLLAMA_KEEP_ALIVE=30m

# -- fallback / hosted (Groq or OpenAI) --
# If Ollama is not available, RepoSage will use Groq (free tier, fast).
# For OpenAI instead, set:
#   HOSTED_BASE_URL=https://api.openai.com/v1
#   HOSTED_MODEL=gpt-4o-mini
#   OPENAI_API_KEY=sk-...
HOSTED_BASE_URL=https://api.groq.com/openai/v1
HOSTED_MODEL=llama-3.1-8b-instant
GROQ_API_KEY=gsk_...
OPENAI_API_KEY=

# ── GitHub citation links (optional) ─────────────────────────────
# If REPO_PATH is a git checkout with an `origin` remote, RepoSage
# auto-detects owner/repo/commit. Override here if needed (e.g. when
# indexing a path that isn't a clone of the public repo).
GITHUB_OWNER=
GITHUB_REPO=
GITHUB_COMMIT=

# ── Retrieval ────────────────────────────────────────────────────
TOP_K=8

# ── Git URL indexing ─────────────────────────────────────────────
# Timeout (seconds) for `git clone` when indexing from a remote URL.
# Set higher for large repos over slow connections.
GIT_CLONE_TIMEOUT=120
